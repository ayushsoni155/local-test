{
  "name": "Feature branch safety (no force push)",
  "target": "branch",
  "source_type": "Repository",
  "enforcement": "active",
  "bypass_actors": [
    {
      "actor_id": 3,
      "actor_type": "RepositoryRole",
      "bypass_mode": "always"
    },
    {
      "actor_id": 5,
      "actor_type": "RepositoryRole",
      "bypass_mode": "always"
    }
  ],
  "conditions": {
    "ref_name": {
      "include": [
        "refs/heads/feature/**",
        "refs/heads/fix/**",
        "refs/heads/hotfix/**",
        "refs/heads/chore/**",
        "refs/heads/refactor/**"
      ],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "non_fast_forward"
    }
  ]
}
